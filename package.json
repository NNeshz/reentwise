{
  "name": "cleely",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "envs": "turbo envs",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "shadcn": "bun --filter @cleely/ui shadcn",
    "db:generate": "bun --filter @cleely/database db:generate",
    "db:migrate": "bun --filter @cleely/database db:migrate",
    "db:push": "bun --filter @cleely/database db:push",
    "db:studio": "bun --filter @cleely/database db:studio",
    "clean-workspaces": "turbo clean-workspace && rm -rf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.7.3",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.2.19",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@elysiajs/cors": "^1.4.0",
    "@elysiajs/openapi": "^1.3.0",
    "@sinclair/typebox": "^0.34.41",
    "@tabler/icons-react": "^3.35.0",
    "@tailwindcss/postcss": "^4.1.17",
    "@tanstack/react-form": "^1.28.3",
    "@tanstack/react-query": "^5.90.21",
    "@vercel/speed-insights": "^2.0.0",
    "better-auth": "^1.4.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "elysia": "^1.4.27",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "tailwind": "^4.0.0",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.11"
  }
}